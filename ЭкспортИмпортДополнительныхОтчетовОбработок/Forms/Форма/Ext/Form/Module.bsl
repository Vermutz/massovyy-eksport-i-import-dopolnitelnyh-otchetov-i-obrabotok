&НаКлиенте
Процедура КаталогВыгрузкиНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
	Диалог.Заголовок = "Выберите каталог для выгрузки обработок";
	
	Если ЗначениеЗаполнено(Объект.КаталогВыгрузки) Тогда
		Диалог.Каталог = Объект.КаталогВыгрузки;
	КонецЕсли;
	
	Если Диалог.Выбрать() Тогда
		Объект.КаталогВыгрузки = Диалог.Каталог;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция КонвертироватьМаскуДляПодобно(Знач пМаска)
	Если ПустаяСтрока(пМаска) Тогда
		Возврат "";
	КонецЕсли;
	
	//сначала *, потом ?, чтобы не было конфликтов
	лРезультат = СтрЗаменить(пМаска, "*", "%");
	лРезультат = СтрЗаменить(лРезультат, "?", "_");
	
	Возврат лРезультат;
КонецФункции

&НаСервере
Процедура КомандаЗаполнитьНаСервере()
	
	Если НЕ Объект.ДобавлятьКСуществующему Тогда
		Объект.ДополнительныеОбработки.Очистить();
	КонецЕсли;	
	
	лУжеДобавлены = Новый Массив;
	Если Объект.ДобавлятьКСуществующему Тогда
		Для Каждого лСтр Из Объект.ДополнительныеОбработки Цикл
			Если ЗначениеЗаполнено(лСтр.Обработка) Тогда
				лУжеДобавлены.Добавить(лСтр.Обработка);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	лИспользоватьПоВиду = ЗначениеЗаполнено(Объект.ОтборВид);
	лИспользоватьПоМаске = ЗначениеЗаполнено(Объект.ОтборМаскаИмени);
	лИспользоватьПоГруппе = ЗначениеЗаполнено(Объект.ОтборГруппа);
	лИспользоватьПоНазначению = ЗначениеЗаполнено(Объект.ОтборНазначение);
	лИспользоватьОпубликованные = Объект.ТолькоОпубликованные;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("ИспользоватьПоВиду", лИспользоватьПоВиду);
	Запрос.УстановитьПараметр("ИспользоватьПоМаске", лИспользоватьПоМаске);
	Запрос.УстановитьПараметр("ИспользоватьПоГруппе", лИспользоватьПоГруппе);
	Запрос.УстановитьПараметр("ИспользоватьПоНазначению", лИспользоватьПоНазначению);
	Запрос.УстановитьПараметр("ИспользоватьОпубликованные", лИспользоватьОпубликованные);
	
	Запрос.УстановитьПараметр("Вид", ?(лИспользоватьПоВиду, Объект.ОтборВид, 
		ПредопределенноеЗначение("Перечисление.ВидыДополнительныхОтчетовИОбработок.ПустаяСсылка")));
	Запрос.УстановитьПараметр("МаскаИмени",	?(лИспользоватьПоМаске, КонвертироватьМаскуДляПодобно(Объект.ОтборМаскаИмени), ""));
	Запрос.УстановитьПараметр("Группа", ?(лИспользоватьПоГруппе, Объект.ОтборГруппа, 
		Справочники.ДополнительныеОтчетыИОбработки.ПустаяСсылка()));
	Запрос.УстановитьПараметр("Назначение", Объект.ОтборНазначение);
	Запрос.УстановитьПараметр("УжеДобавлены", лУжеДобавлены);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДополнительныеОтчетыИОбработкиНазначение.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_Назначения
	|ИЗ
	|	Справочник.ДополнительныеОтчетыИОбработки.Назначение КАК ДополнительныеОтчетыИОбработкиНазначение
	|ГДЕ
	|	ДополнительныеОтчетыИОбработкиНазначение.ОбъектНазначения = &Назначение
	|
	|СГРУППИРОВАТЬ ПО
	|	ДополнительныеОтчетыИОбработкиНазначение.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДополнительныеОтчетыИОбработки.Ссылка КАК Обработка,
	|	ВЫБОР
	|		КОГДА НазначениеТЧ.ОбъектНазначения ЕСТЬ NULL
	|			ТОГДА ""<без назначения>""
	|		ИНАЧЕ НазначениеТЧ.ОбъектНазначения
	|	КОНЕЦ КАК ОбъектНазначения,
	|	ЛОЖЬ КАК Загружен
	|ИЗ
	|	Справочник.ДополнительныеОтчетыИОбработки КАК ДополнительныеОтчетыИОбработки
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Назначения КАК НазначенияПодходящие
	|		ПО ДополнительныеОтчетыИОбработки.Ссылка = НазначенияПодходящие.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДополнительныеОтчетыИОбработки.Назначение КАК НазначениеТЧ
	|		ПО (НазначениеТЧ.Ссылка = ДополнительныеОтчетыИОбработки.Ссылка)
	|			И (НазначениеТЧ.НомерСтроки = 1)
	|ГДЕ
	|	ДополнительныеОтчетыИОбработки.ЭтоГруппа = ЛОЖЬ
	|	И НЕ ДополнительныеОтчетыИОбработки.ПометкаУдаления
	|	И НЕ ДополнительныеОтчетыИОбработки.Ссылка В (&УжеДобавлены)
	|	И (&ИспользоватьПоВиду = ЛОЖЬ
	|			ИЛИ ДополнительныеОтчетыИОбработки.Вид = &Вид)
	|	И (&ИспользоватьПоМаске = ЛОЖЬ
	|			ИЛИ ДополнительныеОтчетыИОбработки.ИмяФайла ПОДОБНО &МаскаИмени)
	|	И (&ИспользоватьПоГруппе = ЛОЖЬ
	|			ИЛИ ДополнительныеОтчетыИОбработки.Родитель В ИЕРАРХИИ (&Группа))
	|	И (&ИспользоватьОпубликованные = ЛОЖЬ
	|			ИЛИ ДополнительныеОтчетыИОбработки.Публикация = ЗНАЧЕНИЕ(Перечисление.ВариантыПубликацииДополнительныхОтчетовИОбработок.Используется))
	|	И (&ИспользоватьПоНазначению = ЛОЖЬ
	|			ИЛИ НазначенияПодходящие.Ссылка ЕСТЬ НЕ NULL )
	|
	|УПОРЯДОЧИТЬ ПО
	|	ОбъектНазначения";
	
	лРезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Если Объект.ДобавлятьКСуществующему Тогда		
		Для Каждого лСтрРез Из лРезультатЗапроса Цикл
			лНоваяСтрока = Объект.ДополнительныеОбработки.Добавить();
			ЗаполнитьЗначенияСвойств(лНоваяСтрока, лСтрРез);
		КонецЦикла;
	Иначе		
		Объект.ДополнительныеОбработки.Загрузить(лРезультатЗапроса);
	КонецЕсли;
	
	лКоличество = Объект.ДополнительныеОбработки.Количество();
	Если лКоличество = 0 Тогда
		Сообщить("По заданным отборам не найдено ни одной обработки.");
	Иначе
		лРежим = ?(Объект.ДобавлятьКСуществующему, "добавлено к существующим", "заменены все");
		Сообщить("Найдено обработок: " + лКоличество + " (" + лРежим + ")", СтатусСообщения.Информация);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаЗаполнить(Команда)
	КомандаЗаполнитьНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура КомандаВыгрузить(Команда)
	Если НЕ ЗначениеЗаполнено(Объект.КаталогВыгрузки) Тогда
		ПоказатьПредупреждение(, "Не указан каталог для выгрузки!");
		Возврат;
	КонецЕсли;
	
	Если Объект.ДополнительныеОбработки.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Список обработок пуст. Выполните команду 'Заполнить'.");
		Возврат;
	КонецЕсли;
	
	лСписокДляВыгрузки = ПодготовитьФайлыКВыгрузкеНаСервере();
	
	Если лСписокДляВыгрузки.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Не найдено ни одной обработки с заполненным хранилищем для выгрузки.");
		Возврат;
	КонецЕсли;
	
	лСчетчикУспешных = 0;
	лЛогОшибок = "";
	
	Для Каждого лЭлементВыгрузки Из лСписокДляВыгрузки Цикл
		лПолныйПутьНаКлиенте = Объект.КаталогВыгрузки;
		Если Прав(лПолныйПутьНаКлиенте, 1) <> "\" Тогда
			лПолныйПутьНаКлиенте = лПолныйПутьНаКлиенте + "\";
		КонецЕсли;
		
		лПолныйПутьНаКлиенте = лПолныйПутьНаКлиенте + лЭлементВыгрузки.ИмяФайла;
		
		Попытка
			Если ПолучитьФайл(лЭлементВыгрузки.АдресВХранилище, лПолныйПутьНаКлиенте, Ложь) Тогда
				лСчетчикУспешных = лСчетчикУспешных + 1;
			Иначе
				лЛогОшибок = лЛогОшибок + "• Не удалось скачать файл: " + лЭлементВыгрузки.ИмяФайла + Символы.ПС;
			КонецЕсли;
		Исключение
			лЛогОшибок = лЛогОшибок + "• Ошибка сохранения '" + лЭлементВыгрузки.ИмяФайла + "': " + ОписаниеОшибки() + Символы.ПС;
		КонецПопытки;
	КонецЦикла;
	
	Если лСчетчикУспешных > 0 Тогда
		лСообщение = "Успешно выгружено обработок: " + лСчетчикУспешных;
		Если ЗначениеЗаполнено(лЛогОшибок) Тогда
			лСообщение = лСообщение + Символы.ПС + Символы.ПС + "Ошибки:" + Символы.ПС + лЛогОшибок;
			ПоказатьПредупреждение(, лСообщение);
		Иначе
			Сообщить(лСообщение, СтатусСообщения.Информация);
		КонецЕсли;
	Иначе
		ПоказатьПредупреждение(, "Выгрузка не выполнена." + Символы.ПС + лЛогОшибок);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПодготовитьФайлыКВыгрузкеНаСервере()
	лРезультат = Новый Массив;
	
	Для Каждого лСтрока Из Объект.ДополнительныеОбработки Цикл
		Если НЕ ЗначениеЗаполнено(лСтрока.Обработка) Тогда
			Продолжить;
		КонецЕсли;
		
		лЭлемент = лСтрока.Обработка.ПолучитьОбъект();
		Если лЭлемент = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		лДвоичныеДанные = лЭлемент.ХранилищеОбработки.Получить();
		Если лДвоичныеДанные = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		лИмяФайла = лЭлемент.ИмяФайла;
		Если НЕ ЗначениеЗаполнено(лИмяФайла) Тогда
			Продолжить;
		КонецЕсли;
		
		лАдрес = ПоместитьВоВременноеХранилище(лДвоичныеДанные);
		
		лСтруктура = Новый Структура;
		лСтруктура.Вставить("ИмяФайла", лИмяФайла);
		лСтруктура.Вставить("АдресВХранилище", лАдрес);
		
		лРезультат.Добавить(лСтруктура);
	КонецЦикла;
	
	Возврат лРезультат;
КонецФункции

&НаКлиенте
Процедура КомандаЗагрузить(Команда)
	Если НЕ ЗначениеЗаполнено(Объект.КаталогВыгрузки) Тогда
		ПоказатьПредупреждение(, "Не указан каталог, из которого нужно загрузить файлы!");
		Возврат;
	КонецЕсли;
	
	лМаскаФайлов = "*.epf";
	лФайлыОбработок = НайтиФайлы(Объект.КаталогВыгрузки, лМаскаФайлов);
	
	лМаскаОтчетов = "*.erf";
	лФайлыОтчетов = НайтиФайлы(Объект.КаталогВыгрузки, лМаскаОтчетов);
	
	лВсеФайлы = Новый Массив;
	Если лФайлыОбработок <> Неопределено Тогда
		Для Каждого лФайл Из лФайлыОбработок Цикл
			лВсеФайлы.Добавить(лФайл);
		КонецЦикла;
	КонецЕсли;
	
	Если лФайлыОтчетов <> Неопределено Тогда
		Для Каждого лФайл Из лФайлыОтчетов Цикл
			лВсеФайлы.Добавить(лФайл);
		КонецЦикла;
	КонецЕсли;
	
	Если лВсеФайлы.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "В указанном каталоге не найдено файлов с расширениями .epf или .erf");
		Возврат;
	КонецЕсли;
	
	лСписокДляЗагрузки = Новый Массив;
	Для Каждого лФайл Из лВсеФайлы Цикл
		Попытка
			лДвоичныеДанные = Новый ДвоичныеДанные(лФайл.ПолноеИмя);
			лАдрес = ПоместитьВоВременноеХранилище(лДвоичныеДанные);
			
			лСтруктура = Новый Структура;
			лСтруктура.Вставить("ИмяФайла", лФайл.Имя);
			лСтруктура.Вставить("Адрес", лАдрес);
			
			лСписокДляЗагрузки.Добавить(лСтруктура);
		Исключение
			Продолжить;
		КонецПопытки;
	КонецЦикла;
	
	Если лСписокДляЗагрузки.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Не удалось прочитать ни один файл из каталога.");
		Возврат;
	КонецЕсли;	
	
	лТекстРезультата = ЗагрузитьФайлыНаСервере(лСписокДляЗагрузки);
	
	Если ЗначениеЗаполнено(лТекстРезультата) Тогда
		Если Найти(лТекстРезультата, "Ошибки:") > 0 Тогда
			ПоказатьПредупреждение(, лТекстРезультата);
		Иначе
			Сообщить(лТекстРезультата, СтатусСообщения.Информация);
		КонецЕсли;
	Иначе
		Сообщить("Обратная загрузка файлов успешно завершена!", СтатусСообщения.Информация);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ЗагрузитьФайлыНаСервере(лСписокДляЗагрузки)
	лУспешноОбновлено = 0;
	лЛогОшибок = "";
	лУспешныеИмена = Новый Массив;
	
	Для Каждого лЭлементЗагрузки Из лСписокДляЗагрузки Цикл
		
		лЭлементСправочника = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоРеквизиту("ИмяФайла", лЭлементЗагрузки.ИмяФайла);
		
		Если НЕ ЗначениеЗаполнено(лЭлементСправочника) Тогда
			лЛогОшибок = лЛогОшибок + "• Не найден элемент справочника с именем файла: " + лЭлементЗагрузки.ИмяФайла + Символы.ПС;
			Продолжить;
		КонецЕсли;
		
		лОбъект = лЭлементСправочника.ПолучитьОбъект();
		Если лОбъект = Неопределено Тогда
			лЛогОшибок = лЛогОшибок + "• Не удалось получить объект для элемента: " + лЭлементЗагрузки.ИмяФайла + Символы.ПС;
			Продолжить;
		КонецЕсли;
		
		лДвоичныеДанные = ПолучитьИзВременногоХранилища(лЭлементЗагрузки.Адрес);
		Если лДвоичныеДанные = Неопределено Тогда
			лЛогОшибок = лЛогОшибок + "• Данные файла '" + лЭлементЗагрузки.ИмяФайла + "' исчезли из временного хранилища." + Символы.ПС;
			Продолжить;
		КонецЕсли;
		
		лОбъект.ХранилищеОбработки = Новый ХранилищеЗначения(лДвоичныеДанные);
		
		Попытка
			лОбъект.Записать();
			лУспешноОбновлено = лУспешноОбновлено + 1;			
			лУспешныеИмена.Добавить(лЭлементЗагрузки.ИмяФайла);
		Исключение
			лЛогОшибок = лЛогОшибок + "• Ошибка записи элемента '" + лЭлементЗагрузки.ИмяФайла + "': " + ОписаниеОшибки() + Символы.ПС;
		КонецПопытки;
		
	КонецЦикла;
		
	Для Каждого лСтрокаТЧ Из Объект.ДополнительныеОбработки Цикл
		Если ЗначениеЗаполнено(лСтрокаТЧ.Обработка) Тогда
			Если лУспешныеИмена.Найти(лСтрокаТЧ.Обработка.ИмяФайла) <> Неопределено Тогда
				лСтрокаТЧ.Загружен = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	лРезультат = "";
	Если лУспешноОбновлено > 0 Тогда
		лРезультат = "Успешно обновлено файлов: " + лУспешноОбновлено;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(лЛогОшибок) Тогда
		Если ЗначениеЗаполнено(лРезультат) Тогда
			лРезультат = лРезультат + Символы.ПС + Символы.ПС;
		КонецЕсли;
		лРезультат = лРезультат + "Ошибки:" + Символы.ПС + лЛогОшибок;
	КонецЕсли;
	
	Возврат лРезультат;
КонецФункции

&НаКлиенте
Процедура КомандаСброситьОтборы(Команда)
	КомандаСброситьОтборыНаСервере();
КонецПроцедуры

&НаСервере
Процедура КомандаСброситьОтборыНаСервере()
	Объект.ОтборВид = Неопределено;
	Объект.ОтборМаскаИмени = "";
	Объект.ОтборГруппа = Неопределено;
	Объект.ОтборНазначение = "";
	Объект.ТолькоОпубликованные = Ложь;
	Объект.ДобавлятьКСуществующему = Ложь;
КонецПроцедуры
